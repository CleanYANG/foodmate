{
  "expo": {
    "name": "fooMate",
    "slug": "foomate",
    "scheme": "foomate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.redhong.foomate",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.redhong.foomate",
      "adaptiveIcon": {
        "backgroundColor": "#FAF4E8",
        "foregroundImage": "./assets/logo.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF4E8",
          "image": "./assets/splash-standard.png",
          "imageWidth": 240
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1ded28c3-1485-4e14-9825-aeac148f51b4"
      }
    }
  }
}
